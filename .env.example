# ============================================================
# JobAlert Environment Variables
# ============================================================
# COPY THIS FILE to ".env" and fill in your values
# NEVER commit .env to GitHub (it contains secrets!)
# ============================================================

# ---- DATABASE ----
# Get free MongoDB from https://cloud.mongodb.com (MongoDB Atlas)
# 1. Create account → New Project → Create Cluster (free tier)
# 2. Database Access → Add user with password
# 3. Network Access → Allow 0.0.0.0/0
# 4. Connect → Connect your application → Copy the URI
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/jobalert

# ---- AUTHENTICATION ----
# Make this a long random string. You can generate one at:
# https://www.allkeysgenerator.com/Random/Security-Encryption-Key-Generator.aspx
JWT_SECRET=your-super-secret-jwt-key-make-this-long-and-random-abc123xyz

# ---- EMAIL (for sending alerts) ----
# Option A: Gmail (easy for development)
# 1. Go to Google Account → Security → 2-Step Verification → App Passwords
# 2. Generate an App Password for "Mail"
# 3. Use that 16-character password below (NOT your Gmail password)
EMAIL_USER=your.email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Option B: SendGrid (better for production, 100 free emails/day)
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.xxxxx

# ---- AI ANALYSIS (optional but recommended) ----
# Get a free API key at https://platform.openai.com
# Free tier gives $5 credit which = ~50,000 job analyses!
# If you leave this empty, the app uses rule-based analysis (still works!)
OPENAI_API_KEY=sk-xxxxx

# ---- APP URLS ----
PORT=5000
FRONTEND_URL=http://localhost:3000
